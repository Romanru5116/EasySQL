# процент заказов с прокодом - 2знака после запятой, показ в процентах
SELECT TO_CHAR(
    (SELECT COUNT(*) FROM orders WHERE promocode_id IS NOT NULL)::float / 
    NULLIF((SELECT COUNT(*) FROM orders), 0) * 100, 
    'FM999990.00'
) AS promo_orders_percentage

#TO_CHAR(..., 'FM999990.00'): Преобразует число в строку. Маска 00 гарантирует показ нулей, а префикс FM убирает лишние пробелы в начале.
# NULLIF(..., 0): Хорошая практика — добавить это деление, чтобы запрос не «упал» с ошибкой, если таблица orders окажется пустой.

